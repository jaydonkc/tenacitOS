[Unit]
Description=Mission Control Dashboard
After=default.target

[Service]
Type=simple
WorkingDirectory=/home/jaydonkc/newdash/tenacitOS
Environment=NODE_ENV=production
Environment=PATH=/home/jaydonkc/.nvm/versions/node/v22.19.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/home/jaydonkc/.nvm/versions/node/v22.19.0/bin/npm start
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=default.target
